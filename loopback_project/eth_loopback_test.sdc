# eth_loopback_test.sdc
# Timing constraints for eth_loopback_test on DE2-115
#
# Sources:
#   - DE2-115 reference fpga.sdc (clock definitions, false paths)
#   - mii_phy_if.sdc (MII reset sync false paths)
#   - eth_mac_1g_gmii.sdc (CDC max_delay constraints)

# ── Clock definitions ────────────────────────────────────────────────────────
# 50MHz system oscillator on PIN_Y2
create_clock -name {CLOCK_50} -period 20.000 [get_ports {CLOCK_50}]

# 25MHz MII receive clock generated by Marvell 88E1111 PHY (100BASE-T)
# This is an input clock from an external chip — asynchronous to CLOCK_50
create_clock -name {ENET0_RX_CLK} -period 40.000 [get_ports {ENET0_RX_CLK}]

# JTAG clock (USB Blaster)
create_clock -name {altera_reserved_tck} -period 40.000 {altera_reserved_tck}

# ── Clock domain isolation ───────────────────────────────────────────────────
# CLOCK_50 and ENET0_RX_CLK are completely asynchronous.
# The toggle handshake CDC in eth_mac_bridge handles crossing safely.
# Tell TimeQuest not to check paths between these domains.
set_clock_groups -asynchronous -group [get_clocks {CLOCK_50}]
set_clock_groups -asynchronous -group [get_clocks {ENET0_RX_CLK}]
set_clock_groups -asynchronous -group [get_clocks {altera_reserved_tck}]

# ── JTAG pin constraints ────────────────────────────────────────────────────
set_input_delay  -clock altera_reserved_tck 5 [get_ports altera_reserved_tdi]
set_input_delay  -clock altera_reserved_tck 5 [get_ports altera_reserved_tms]
set_output_delay -clock altera_reserved_tck -clock_fall -fall -max 5 \
                 [get_ports altera_reserved_tdo]

# ── False paths: slow/static IOs ────────────────────────────────────────────
# Buttons, LEDs, HEX displays, PHY control — no timing closure needed
set_false_path -from [get_ports {KEY[*]}]  -to *
set_false_path -from * -to [get_ports {LEDR[*]}]
set_false_path -from * -to [get_ports {LEDG[*]}]
set_false_path -from * -to [get_ports {HEX0[*]}]
set_false_path -from * -to [get_ports {HEX1[*]}]
set_false_path -from * -to [get_ports {HEX2[*]}]
set_false_path -from * -to [get_ports {HEX3[*]}]
set_false_path -from * -to [get_ports {HEX4[*]}]
set_false_path -from * -to [get_ports {HEX5[*]}]
set_false_path -from * -to [get_ports {ENET0_RST_N}]
set_false_path -from * -to [get_ports {ENET0_MDC}]

# ── Toggle CDC max_delay constraints ────────────────────────────────────────
# The toggle handshake in eth_mac_bridge uses a 3-stage synchronizer.
# At 100BASE-T a byte arrives every 80ns (2 system clocks at 50MHz).
# The first synchronizer stage must settle within one CLOCK_50 period (20ns).
# Set max_delay on the crossing register to give TimeQuest the right picture.
set_max_delay -from [get_registers {u_bridge|mii_toggle}] \
              -to   [get_registers {u_bridge|tog_sync[0]}] \
              20.000

# Data registers resampled in CLOCK_50 domain — 2 cycles of settling time
set_max_delay -from [get_registers {u_bridge|mii_byte}] \
              -to   [get_registers {u_bridge|byte_s1}] \
              40.000
set_max_delay -from [get_registers {u_bridge|mii_sof}] \
              -to   [get_registers {u_bridge|sof_s1}] \
              40.000
set_max_delay -from [get_registers {u_bridge|mii_eof}] \
              -to   [get_registers {u_bridge|eof_s1}] \
              40.000

# Reset synchronizer false path (from mii_phy_if.sdc pattern)
set_false_path -from * -to [get_registers {u_bridge|*rst*}]

derive_clock_uncertainty